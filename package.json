{
  "name": "focus-timer",
  "version": "0.1.0",
  "description": "ADHD/ASD-friendly Pomodoro timer Chrome extension (Manifest V3)",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "lint": "tsc --noEmit",
    "test": "node --test --experimental-strip-types --no-warnings tests/*.test.ts",
    "test:run": "node --test --experimental-strip-types --no-warnings tests/*.test.ts",
    "check:i18n": "node scripts/check-i18n.mjs",
    "package": "npm run build && node scripts/package.mjs"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/node": "^25.8.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.10"
  }
}
